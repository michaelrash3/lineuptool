{
    "include": [
        "./src/**/*"
    ],
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": false,
        "strict": true,
        "esModuleInterop": true,
        "lib": [
            "dom",
            "dom.iterable",
            "es2020"
        ],
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "isolatedModules": true,
        "noEmit": true,
        "resolveJsonModule": true
    }
}