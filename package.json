{
  "name": "coachs-card",
  "version": "1.0.0",
  "description": "Youth baseball lineup, roster, schedule, and tryout management app",
  "keywords": [
    "baseball",
    "lineup",
    "roster",
    "coaching",
    "tryouts",
    "react",
    "typescript"
  ],
  "main": "src/index.tsx",
  "dependencies": {
    "@sentry/react": "^8.55.2",
    "firebase": "12.12.0",
    "jspdf": "^4.2.1",
    "lucide-react": "1.8.0",
    "qrcode": "^1.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "@types/react": "18.2.38",
    "@types/react-dom": "18.2.15",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-admin": "^13.10.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "4.9.5",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config firestore-tests/vitest.config.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
