rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /artifacts/{appId}/users/{uid}/settings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /artifacts/{appId}/public/data/teams/{teamId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function membersList(data) {
        return data.members != null ? data.members : [];
      }

      function isMember(data) {
        return isSignedIn() && (
          data.ownerId == request.auth.uid ||
          request.auth.uid in membersList(data)
        );
      }

      // Base team access: owners/members can read + write team docs.
      allow read, write: if isMember(resource.data);

      // Team bootstrap: signed-in creator can create new team doc when ownerId
      // is set to their UID.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Team join code lookup/read path.
      allow read: if isSignedIn() && resource.data.joinCode != null;

      // Join-code self-join path. Caller may only modify members + coachRoles.
      allow update: if isSignedIn()
                    && resource.data.joinCode != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['members', 'coachRoles']);

      // Public tryouts path (anonymous auth included):
      // - read themed team info while open
      // - append to tryoutSignups only
      allow read: if isSignedIn() && resource.data.tryoutsOpen == true;

      allow update: if isSignedIn()
                    && resource.data.tryoutsOpen == true
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['tryoutSignups']);
    }
  }
}
