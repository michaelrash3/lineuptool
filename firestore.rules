rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /artifacts/{appId}/users/{uid}/settings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /artifacts/{appId}/public/data/teams/{teamId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function membersList(data) {
        return data.members != null ? data.members : [];
      }

      function isMember(data) {
        return isSignedIn() && (
          data.ownerId == request.auth.uid ||
          request.auth.uid in membersList(data)
        );
      }

      function isCurrentOwner() {
        return isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

      // Head coach = the current owner OR a member the owner promoted to
      // 'head' via coachRoles (setCoachRole in useTeamMembership). Owner-only
      // would break promoted co-heads. Always evaluated against resource.data
      // (the PRE-write roles), so a write can never grant itself the very
      // privilege it needs.
      function isHeadCoach() {
        return isSignedIn() && (
          resource.data.ownerId == request.auth.uid ||
          resource.data.get('coachRoles', {}).get(request.auth.uid, '') == 'head'
        );
      }

      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }

      function untouched(key) {
        return !changedKeys().hasAny([key]);
      }

      // Hard ceiling on public signup arrays — bounds the cost/DoS surface of
      // the anonymous tryout/interest write paths below.
      function MAX_SIGNUPS() {
        return 2000;
      }

      // Size of an existing signup array, or 0 when the field is absent (so the
      // very first append is permitted).
      function prevSignupCount(key) {
        return key in resource.data ? resource.data[key].size() : 0;
      }

      // The existing signup array (or an empty list when the field is absent).
      function prevSignups(key) {
        return key in resource.data ? resource.data[key] : [];
      }

      // True when the write appends EXACTLY ONE entry to `key` and leaves every
      // prior entry in place:
      //   - size grows by exactly one (no multi-add, no shrink), and
      //   - every previous element is still present (no remove/replace), and
      //   - the array never exceeds the DoS ceiling.
      // toSet().hasAll(prev) is the documented append-only pattern: a public
      // caller can arrayUnion a single new signup but can't drop or rewrite the
      // other families' entries already on the doc.
      function appendsExactlyOne(key) {
        return request.resource.data[key].size() == prevSignupCount(key) + 1
          && request.resource.data[key].size() <= MAX_SIGNUPS()
          && request.resource.data[key].toSet().hasAll(prevSignups(key).toSet());
      }

      function ownerIdUnchanged() {
        return !changedKeys().hasAny(['ownerId']);
      }

      function prevMembers() {
        return resource.data.members != null ? resource.data.members : [];
      }

      function nextMembers() {
        return request.resource.data.members != null
          ? request.resource.data.members
          : [];
      }

      function membersAppendOnly() {
        // Every existing member must still be present after the write.
        return nextMembers().toSet().hasAll(prevMembers().toSet());
      }

      function prevCoachRoles() {
        return resource.data.coachRoles != null ? resource.data.coachRoles : {};
      }

      function nextCoachRoles() {
        return request.resource.data.coachRoles != null
          ? request.resource.data.coachRoles
          : {};
      }

      function coachRolesSelfJoinValid() {
        // On the join-code self-join path the caller may only touch their
        // OWN coachRoles entry (existing entries stay byte-for-byte), and
        // that entry must be a real role — never an arbitrary string the
        // role-resolution logic would silently ignore or that could be
        // used to smuggle a bogus privilege value. Mirrors the client
        // guard in useTeamMembership.setCoachRole.
        // The legit client join path (useInviteFlows.joinTeamByCode) only
        // ever sets 'assistant'. Allowing 'head' here let any code-holder —
        // or any EXISTING member reusing this OR'd clause — self-promote to
        // head; promotion to 'head' is the owner's/heads' act through the
        // base update rule.
        return nextCoachRoles().diff(prevCoachRoles()).affectedKeys()
                 .hasOnly([request.auth.uid])
          && nextCoachRoles()[request.auth.uid] == 'assistant';
      }

      function selfRemoveOnly() {
        // The only delta is the caller's own UID being removed (leave-team).
        return prevMembers().toSet().difference(nextMembers().toSet())
          .hasOnly([request.auth.uid]);
      }

      function isLegitimateAutoClaim() {
        // Team is genuinely unowned AND caller becomes the new owner AND no
        // other members exist on the previous doc. Mirrors the client-side
        // auto-claim guard in App.jsx — the same race-prevention check that
        // shipped in PR #123 is enforced here at the rules layer so a
        // misbehaving client can't bypass it.
        return (!('ownerId' in resource.data)
                || resource.data.ownerId == null
                || resource.data.ownerId == "")
          && request.resource.data.ownerId == request.auth.uid
          && prevMembers().toSet().difference([request.auth.uid].toSet()).size() == 0;
      }

      // ----- Base team access -----
      // Members can read. Members can update only when:
      //   - ownerId stays the same OR caller is the current owner OR it's a
      //     legitimate first-time auto-claim, AND
      //   - members[] doesn't shrink OR caller is the current owner OR caller
      //     is only removing themselves (assistant leaving a team).
      // The previous "members can write anything" stance was what let the
      // ownership-takeover race demote a head coach in production. The PR
      // #123 client-side guard closes the race in our own code; this rules
      // tightening closes it for any client (or future bug) too.
      allow read: if isMember(resource.data);
      allow update: if isMember(resource.data)
                    && (ownerIdUnchanged() || isCurrentOwner() || isLegitimateAutoClaim())
                    && (membersAppendOnly() || isCurrentOwner() || selfRemoveOnly())
                    // finances is head-coach-only (docs/FINANCES-AUDIT.md
                    // finding 3.1). Reads cannot be field-gated on a single
                    // doc, so assistants can still READ finances — a
                    // documented, accepted residual.
                    && (untouched('finances') || isHeadCoach())
                    // Without this, any member could self-promote to 'head'
                    // with a plain coachRoles write and then sail through the
                    // finances gate above.
                    && (untouched('coachRoles') || isHeadCoach())
                    // evaluationEvents is a DROPPED legacy field (finding 3.1
                    // — rounds live in the evalRounds subcollection below).
                    // Ratchet: a doc still carrying the array may rewrite or
                    // remove it (schema-ladder migration, the deleteField
                    // drop), but once gone no write may recreate it — that
                    // would put scoped eval data back on the shared doc.
                    && (!('evaluationEvents' in request.resource.data)
                        || ('evaluationEvents' in resource.data));

      // Only the current owner can delete the team document.
      allow delete: if isCurrentOwner();

      // Team bootstrap: signed-in creator can create a new team doc when
      // ownerId is set to their UID. A new doc can never be born with the
      // dropped legacy evaluationEvents field (see the update-rule ratchet) —
      // combined, the field can only ever disappear from the fleet.
      allow create: if isSignedIn()
                    && request.resource.data.ownerId == request.auth.uid
                    && !('evaluationEvents' in request.resource.data);

      // NOTE: there is deliberately NO "read if a join code exists" rule here.
      // The old `allow read: if isSignedIn() && resource.data.joinCode != null;`
      // leaked the ENTIRE private team doc (roster, evaluations, every family's
      // signup PII, member UIDs, ownerId) to any signed-in user who merely knew
      // a code existed. Join-code resolution now goes through the sanitized
      // /teamInvites/{code} lookup doc below, which exposes only teamId +
      // teamName; the constrained self-join update rule still lets the invited
      // user add themselves to this team doc without reading it.

      // Join-code self-join path. Caller may only modify members + coachRoles,
      // can never shrink the members list, and must add themselves as a
      // member by the end of the write. The base-update rule's ownerId
      // protection still applies on top of this — a code-holder cannot
      // rewrite the ownership shape.
      allow update: if isSignedIn()
                    && resource.data.joinCode != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['members', 'coachRoles'])
                    && membersAppendOnly()
                    // The caller may add exactly themselves — never smuggle
                    // extra uids into members in the same write.
                    && nextMembers().toSet().difference(prevMembers().toSet())
                         .hasOnly([request.auth.uid])
                    && request.auth.uid in nextMembers()
                    && coachRolesSelfJoinValid();

      // Public tryouts write path (anonymous auth included):
      // - append to tryoutSignups only while tryouts are open.
      // - append to interestSignups any time (interest is collected
      //   year-round; there's no "interest-open" flag).
      // NOTE: there is deliberately NO public *read* of the full team doc.
      // The Tryouts Portal reads branding + tryout config from the sanitized
      // teamPublic mirror (below) instead, so anonymous parents never see
      // evaluations, other families' signups, member UIDs, or the join code.
      // These writes don't require read access — rules evaluate resource.data
      // server-side — so signups continue to work.
      //
      // Growth + integrity caps: a `hasOnly()` + size bound alone would still
      // let an anonymous caller REPLACE the array with a same-or-smaller payload
      // (dropping or rewriting other families' entries). appendsExactlyOne()
      // requires the size to grow by exactly one AND every prior entry to
      // survive (toSet().hasAll(prev)), so a public write can only ever tack on
      // a single new signup — never remove, replace, or multi-add. The empty
      // prev set (first-ever signup) trivially satisfies hasAll, so the first
      // append is allowed.
      allow update: if isSignedIn()
                    && resource.data.tryoutsOpen == true
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['tryoutSignups'])
                    && appendsExactlyOne('tryoutSignups');

      allow update: if isSignedIn()
                    && resource.data.tryoutShareId != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['interestSignups'])
                    && appendsExactlyOne('interestSignups');

      // Public player-info write path (anonymous auth included): a parent
      // submits uniform/equipment sizing + logistics for a rostered kid via
      // the same standing share link as the interest form. Allowed any time a
      // share link exists (no open/closed gate — sizing is collected
      // year-round). Same append-only integrity caps as the signup paths.
      allow update: if isSignedIn()
                    && resource.data.tryoutShareId != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['playerInfoSubmissions'])
                    && appendsExactlyOne('playerInfoSubmissions');

      // Public availability write path (anonymous auth included): a parent
      // submits the dates their kid is unavailable via the same standing share
      // link. Allowed any time a share link exists. Same append-only integrity
      // caps as the other public arrays.
      allow update: if isSignedIn()
                    && resource.data.tryoutShareId != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['availabilitySubmissions'])
                    && appendsExactlyOne('availabilitySubmissions');

      // ----- Per-author evaluation rounds (docs/eval-authz-design.md, Option
      // A — the fix for audit finding 3.1). This subcollection is the SOLE
      // home for eval rounds: reads and writes are authorization-scoped — an
      // assistant sees and edits only their OWN rounds; a head coach (the
      // owner or a coachRoles 'head') manages every round. The old
      // `evaluationEvents` array on the shared team doc (which no rule could
      // field-scope) has been dropped; the ratchet in the base update rule
      // above keeps it from ever coming back.
      match /evalRounds/{roundId} {
        function teamDoc() {
          return get(/databases/$(database)/documents/artifacts/$(appId)/public/data/teams/$(teamId)).data;
        }
        function isTeamMember() {
          return isSignedIn() && (
            teamDoc().ownerId == request.auth.uid ||
            (teamDoc().members != null && request.auth.uid in teamDoc().members)
          );
        }
        // Head coach = owner OR a member promoted to 'head' via coachRoles,
        // matching isHeadCoach() on the team doc.
        function isTeamHead() {
          return isSignedIn() && (
            teamDoc().ownerId == request.auth.uid ||
            teamDoc().get('coachRoles', {}).get(request.auth.uid, '') == 'head'
          );
        }
        // The signed-in caller authored this existing round.
        function isOwnRound() {
          return isSignedIn() && resource.data.evaluatorId == request.auth.uid;
        }

        // Head reads every round; an assistant reads only their own. This also
        // scopes list queries: a head may list all, an assistant only a
        // `where evaluatorId == me` query.
        allow read: if isTeamHead() || isOwnRound();
        // A member may create a round only when it is stamped with their own
        // uid — nobody can plant a round under someone else's name.
        allow create: if isTeamMember()
                      && request.resource.data.evaluatorId == request.auth.uid;
        // Head manages every round; an author manages their own. evaluatorId is
        // immutable on update, so a round can never be reassigned to a
        // different author (delete + recreate instead).
        allow update: if (isTeamHead() || isOwnRound())
                      && request.resource.data.evaluatorId == resource.data.evaluatorId;
        allow delete: if isTeamHead() || isOwnRound();
      }
    }

    // Sanitized public mirror of a team, maintained by the coach client
    // (see buildPublicMirror in src/utils/helpers.ts). Holds only branding +
    // tryout config — never roster, schedule, evaluations, signups, members,
    // ownerId, coachRoles, or joinCode. The Tryouts Portal (anonymous auth)
    // reads it; only members of the underlying team may write it.
    match /artifacts/{appId}/public/data/teamPublic/{teamId} {
      function mainTeam() {
        return get(/databases/$(database)/documents/artifacts/$(appId)/public/data/teams/$(teamId)).data;
      }
      function isTeamMember() {
        return request.auth != null && (
          mainTeam().ownerId == request.auth.uid ||
          (mainTeam().members != null
            && request.auth.uid in mainTeam().members)
        );
      }

      // Anonymous portal visitors (signed in anonymously) may read the mirror.
      allow read: if request.auth != null;
      // Only a member of the real team can create/update/delete the mirror.
      allow write: if isTeamMember();
    }

    // Sanitized invite lookup, keyed by join code. Replaces the old "read the
    // whole team doc if it has a join code" rule: a code-holder resolves the
    // code to a teamId + teamName here (nothing private), then performs the
    // constrained self-join update against the real team doc. Maintained by the
    // coach client (see regenerateJoinCode / invite backfill in App.tsx).
    match /artifacts/{appId}/public/data/teamInvites/{code} {
      function teamData(teamId) {
        return get(/databases/$(database)/documents/artifacts/$(appId)/public/data/teams/$(teamId)).data;
      }
      function isMemberOfTeam(teamId) {
        return request.auth != null
          && (teamData(teamId).ownerId == request.auth.uid
              || (teamData(teamId).members != null
                  && request.auth.uid in teamData(teamId).members));
      }

      // Any signed-in user may read an invite to resolve a join code. The doc
      // is sanitized — only teamId, teamName, and updatedAt.
      allow read: if request.auth != null;
      // Only a member of the referenced team may create/update the invite, and
      // the teamId it points at must be one the caller actually belongs to (so
      // a code can't be squatted to redirect joiners at someone else's team).
      allow create, update: if request.auth != null
        && request.resource.data.teamId is string
        && isMemberOfTeam(request.resource.data.teamId);
      // Code rotation deletes the stale invite; limited to a team member.
      allow delete: if request.auth != null && isMemberOfTeam(resource.data.teamId);
    }
  }
}
